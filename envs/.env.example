# Application
APP_PORT=4000
APP_ENV=development
CORS_ORIGINS=http://localhost:3000

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=starter
DB_SSLMODE=disable
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=5

# Redis (optional — falls back to no-op cache when unreachable)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_POOL_SIZE=10

# JWT
JWT_SECRET=please-change-me-in-production
JWT_TTL_HOURS=24

# Object storage (MinIO defaults; set AWS_ENDPOINT="" and UsePathStyle=false for real AWS S3)
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_DEFAULT_REGION=us-east-1
AWS_ENDPOINT=http://localhost:9000
AWS_BUCKET=starter
AWS_USE_PATH_STYLE_ENDPOINT=true
